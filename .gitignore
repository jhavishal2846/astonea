# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# OpenNext / Cloudflare build output — regenerated by `npm run build:cf`
/.open-next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.dev.vars
.dev.vars.*

# Cloudflare / D1 local state — includes the local D1 sqlite file and
# any session bookmarks. Never commit.
/.wrangler
*.sqlite
*.sqlite-journal
*.db
*.db-journal

# Neon → D1 migration dump (contains real prod row data). The script
# in scripts/migrate-neon-to-d1.ts writes here.
/dump.sql
/dump.preview.sql
/migration-failures.csv
/migration-mapping.csv

# FTS5 rebuild helpers — one is a checked-in manual fix file we don't need
# under VCS, the other is a temp file the migration script writes.
/fts-rebuild.sql
/fts-rebuild.tmp.sql

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
